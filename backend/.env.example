NODE_ENV=development
PORT=3333

# Firebase Admin SDK - obtenha em: Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=seu-projeto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu-projeto-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=seu-projeto-id.appspot.com

# JWT
JWT_SECRET=facilita-imobiliaria-jwt-secret-super-seguro-2024
JWT_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# App
APP_NAME=Pedro Baranda
APP_URL=http://localhost:3333
FRONTEND_URL=http://localhost:5173

# PIX (para geração de QR Codes)
PIX_CIDADE=Sua Cidade
PIX_CEP=00000000
